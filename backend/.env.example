# DeepShield Backend Configuration

# Flask Configuration
FLASK_ENV=development
DEBUG=True
SECRET_KEY=deepshield-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-key-here

# Server Configuration
HOST=0.0.0.0
PORT=5000

# File Upload Configuration
MAX_FILE_SIZE=500  # MB
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS_IMAGE=png,jpg,jpeg,bmp,gif
ALLOWED_EXTENSIONS_VIDEO=mp4,avi,mov,mkv,flv,wmv
ALLOWED_EXTENSIONS_AUDIO=mp3,wav,flac,aac,ogg,m4a

# Model Configuration
MODEL_PATH=models/
XCEPTIONNET_MODEL=xceptionnet_model.h5
AUDIO_CNN_MODEL=audio_cnn_model.h5

# Analysis Configuration
VIDEO_FRAME_COUNT=15
ANALYSIS_TIMEOUT=300  # seconds
CONFIDENCE_THRESHOLD=0.5

# Fusion Weights
FUSION_IMAGE_WEIGHT=0.35
FUSION_VIDEO_WEIGHT=0.35
FUSION_AUDIO_WEIGHT=0.30

# Database Configuration - Firestore (Primary) with SQLite Backup
# Option 1: Use credentials file path
FIREBASE_CREDENTIALS_PATH=database_info.json

# Option 2: Use environment variable with JSON string
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# SQLite Database (Automatic backup)
SQLALCHEMY_DATABASE_URI=sqlite:///deepfake_detection.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/deepshield.log

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,*

# Email Configuration (Brevo for OTP and notifications)
BREVO_API_KEY=your-brevo-api-key-here

# AI Assistant Configuration
GROQ_API_KEY=your-groq-api-key-here
